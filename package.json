{
  "name": "gmc-creative-machine",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter dashboard dev",
    "worker:dev": "pnpm --filter worker dev",
    "db:migrate": "supabase db push",
    "pipeline:test": "pnpm --filter worker pipeline:test",
    "pipeline:test-selection": "pnpm --filter worker pipeline:test-selection",
    "format:scan": "pnpm --filter worker format:scan",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
