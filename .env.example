# Copy to .env.local at the REPO ROOT — both apps (dashboard + worker) load it.
# Never commit real values.

# Supabase (Phase 0)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Grid thumbnails use Storage image transformations (Supabase Pro+ plan).
# Set to 0 to serve full-resolution images everywhere (free tier).
# NEXT_PUBLIC_SUPABASE_IMAGE_TRANSFORMS=0

# Phase 1+ (leave empty until needed)
ANTHROPIC_API_KEY=
# Optional admin key (sk-ant-admin…) for org-wide cost on the Usage page;
# without it Anthropic spend falls back to internal metering from runs.
ANTHROPIC_ADMIN_KEY=
# Optional: model for worker pipeline agents (default claude-sonnet-5)
# WORKER_MODEL=

# Apify — reddit-miner (Phase 1) and Facebook Ad Library (Phase 2).
# Without it the reddit-miner is skipped with a warning.
APIFY_TOKEN=
# fal.ai — Phase 3 still-ad generation (Nano Banana Pro). Verify with pnpm fal:test.
FAL_API_KEY=
GEMINI_API_KEY=
HIGGSFIELD_API_KEY=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
