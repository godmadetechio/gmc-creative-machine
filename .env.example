# Copy to .env.local at the REPO ROOT — both apps (dashboard + worker) load it.
# Never commit real values.

# Supabase (Phase 0)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 1+ (leave empty until needed)
ANTHROPIC_API_KEY=
# Optional: model for worker pipeline agents (default claude-sonnet-5)
# WORKER_MODEL=

# Reddit Data API (reddit-miner) — register a "script" app at
# https://www.reddit.com/prefs/apps. Without these the reddit-miner is
# skipped with a warning. User-Agent format per Reddit API rules, e.g.
# "godmade-client-machine/1.0 by u_yourusername"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
APIFY_TOKEN=
GEMINI_API_KEY=
HIGGSFIELD_API_KEY=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
